{
  "name": "imagemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "imagemon": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:skill": "node scripts/build-skill.mjs",
    "check:skill": "node scripts/check-skill.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run build && npm run typecheck && npm test && npm run check:skill"
  },
  "dependencies": {
    "openai": "^6.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
