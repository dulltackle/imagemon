{
  "expo": {
    "name": "Imagemon",
    "slug": "imagemon-mobile",
    "version": "0.6.0",
    "orientation": "portrait",
    "scheme": "imagemon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.forclaw.imagemon"
    },
    "android": {
      "package": "dev.forclaw.imagemon"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Imagemon 需要访问相册，以便选择编辑任务的输入图片。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
