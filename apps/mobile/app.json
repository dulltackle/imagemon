{
  "expo": {
    "name": "Imagemon",
    "slug": "imagemon-mobile",
    "version": "0.5.1",
    "orientation": "portrait",
    "scheme": "imagemon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.forclaw.imagemon"
    },
    "android": {
      "package": "dev.forclaw.imagemon"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
